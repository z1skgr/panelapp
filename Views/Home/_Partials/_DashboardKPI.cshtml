@model panelapp.ViewModels.HomeDashboardViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Αρχική";

    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="dashboard-kpi-strip card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-3 align-items-center">

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-primary">
                        <i class="bi bi-building"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Top Πελάτης</div>
                        <div class="mini-kpi-value mini-kpi-truncate">
                            @Model.TopCustomerName
                            @if (Model.TopCustomerPanelCount > 0)
                            {
                                <span class="mini-kpi-count">(@Model.TopCustomerPanelCount)</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-info text-dark">
                        <i class="bi bi-calendar3"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Πίνακες Μήνα</div>
                        <div class="mini-kpi-value">@Model.PanelsThisMonth</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-info text-dark">
                        <i class="bi bi-file-earmark-text"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Προσφορές Μήνα</div>
                        <div class="mini-kpi-value">@Model.OffersThisMonth</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-success">
                        <i class="bi bi-check2-circle"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Acceptance Προσφορες Rate</div>
                        <div class="mini-kpi-value">@Model.OfferAcceptanceRate%</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-warning text-dark">
                        <i class="bi bi-pencil-square"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Draft Προσφορές</div>
                        <div class="mini-kpi-value">@Model.DraftOffers</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-primary">
                        <i class="bi bi-people"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Ενεργοί Πελάτες</div>
                        <div class="mini-kpi-value">@Model.ActiveCustomers</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-success">
                        <i class="bi bi-check-circle"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Accepted Προσφορές Μήνα</div>
                        <div class="mini-kpi-value">@Model.AcceptedOffersThisMonth</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="mini-kpi">
                    <span class="mini-kpi-icon bg-secondary">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </span>
                    <div>
                        <div class="mini-kpi-label">Completed Πινακες Μήνα</div>
                        <div class="mini-kpi-value">@Model.CompletedPanelsThisMonth</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>