@model panelapp.ViewModels.HomeDashboardViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Αρχική";

    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var totalSuppliers = Model.TotalSuppliers > 0
        ? Model.TotalSuppliers
        : Model.ActiveSuppliers + Model.InactiveSuppliers;
}

<partial name="_Partials/_DashboardHero" model="Model" />
<partial name="_Partials/_DashboardStatsCarousel" model="Model" />
<partial name="_Partials/_DashboardKPI" model="Model" />

<div class="row g-4 mb-4">
    <partial name="_Partials/_DashboardRecentPanels" model="Model" />

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100 dashboard-activity-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="quick-actions-icon">
                            <i class="bi bi-clock-history"></i>
                        </span>

                        <div>
                            <h2 class="h5 mb-0">Τελευταία Δραστηριότητα</h2>
                            <div class="text-muted small">Οι πιο πρόσφατες αλλαγές</div>
                            <a asp-controller="ActivityLogs" asp-action="Index" class="btn btn-outline-secondary btn-sm app-btn-sm">
                                Όλες
                            </a>
                        </div>
                    </div>
                </div>

                <partial name="_Partials/_DashboardActivityFeed" model="Model" />

                <hr class="my-4" />

                <partial name="_Partials/_DashboardQuickActions" model="Model" />
            </div>
        </div>
    </div>
</div>

<partial name="_Partials/_DashboardChart" model="Model" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.dashboardChartData = @Html.Raw(ViewBag.ChartData ?? "[]");
    </script>
    <script src="~/js/dashboard-index.js" asp-append-version="true"></script>
    <script src="~/js/dashboard-llm.js" asp-append-version="true"></script>
}