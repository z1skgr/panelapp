@model panelapp.ViewModels.SupplierDiscountsModalViewModel

<div class="modal fade supplier-discounts-modal"
     id="supplierDiscountsModal"
     tabindex="-1"
     aria-labelledby="supplierDiscountsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content supplier-discounts-modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="supplierDiscountsModalLabel">
                    <i class="bi bi-percent me-1"></i>
                    Default Εκπτώσεις Προμηθευτών
                </h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Κλείσιμο"></button>
            </div>

            <div class="modal-body">
                @if (Model == null || !Model.Suppliers.Any())
                {
                    <div class="text-muted">
                        Δεν υπάρχουν ενεργοί προμηθευτές.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Προμηθευτής</th>
                                    <th class="text-end">Default Έκπτωση</th>
                                    <th style="width: 220px;">Νέα Έκπτωση</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var supplier in Model.Suppliers)
                                {
                                    var actionName = Model.SourceType == "Offer"
                                        ? "UpdateSupplierDiscountForOffer"
                                        : "UpdateSupplierDiscountForPanel";

                                    <tr>
                                        <td>@supplier.SupplierName</td>

                                        <td class="text-end">
                                            @supplier.DefaultDiscountPercent.ToString("0.##") %
                                        </td>

                                        <td style="width: 150px;">
                                            <form asp-controller="@(Model.SourceType == "Offer" ? "Offers" : "Panels")"
                                                  asp-action="@actionName"
                                                  method="post"
                                                  class="d-flex gap-2 align-items-center">

                                                @Html.AntiForgeryToken()

                                                @if (Model.SourceType == "Offer")
                                                {
                                                    <input type="hidden" name="offerId" value="@Model.SourceId" />
                                                }
                                                else
                                                {
                                                    <input type="hidden" name="panelId" value="@Model.SourceId" />
                                                }

                                                <input type="hidden" name="supplierId" value="@supplier.SupplierID" />

                                                <input type="number"
                                                       name="discountPercent"
                                                       value="@supplier.DefaultDiscountPercent"
                                                       min="0"
                                                       max="100"
                                                       step="0.01"
                                                       class="form-control form-control-sm" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-primary has-loading-state">
                                                    <span class="btn-text">
                                                        Εφαρμογή
                                                    </span>

                                                    <span class="btn-spinner">
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    </span>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary app-btn" data-bs-dismiss="modal">
                    Κλείσιμο
                </button>
            </div>
        </div>
    </div>
</div>