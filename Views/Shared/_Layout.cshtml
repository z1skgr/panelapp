@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    var username = Context.Session.GetString("Username");
    var fullName = Context.Session.GetString("FullName");
    var roleName = Context.Session.GetString("RoleName");
    var isLoggedIn = !string.IsNullOrWhiteSpace(username);
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Panel App</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="~/favicon.ico" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm app-navbar">
            <div class="container-fluid px-3 px-md-4">

                <a class="navbar-brand app-brand d-flex align-items-center justify-content-center gap-2 fw-semibold"
                   asp-controller="Home"
                   asp-action="Index">
                    <i class="bi bi-grid-3x3-gap-fill text-success app-brand-icon"></i>
                    © @DateTime.Now.Year <span class="fw-semibold text-dark">Panel App</span>
                </a>

                <div class="d-flex align-items-center order-lg-2 ms-auto">
                    @if (Env.IsDevelopment())
                    {
                        <span class="badge bg-warning text-dark me-2">DEV</span>
                    }
                    else if (Env.IsProduction())
                    {
                        <span class="badge bg-success me-2">PROD</span>
                    }

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                            aria-controls="mainNavbar" aria-expanded="false" aria-label="Εναλλαγή πλοήγησης">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                <div class="collapse navbar-collapse order-lg-1" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (isLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Αρχική
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Panels" asp-action="Index">
                                    <i class="bi bi-lightning-charge me-1"></i>Πίνακες
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Panels" asp-action="Create">
                                    <i class="bi bi-plus-circle me-1"></i>Νέος Πίνακας
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Materials" asp-action="Index">
                                    <i class="bi bi-box-seam me-1"></i>Υλικά
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Suppliers" asp-action="Index">
                                    <i class="bi bi-building me-1"></i>Προμηθευτές
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customers" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Πελάτες
                                </a>
                            </li>

                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Materials" asp-action="Import">
                                        <i class="bi bi-file-earmark-excel me-1"></i>Εισαγωγή Υλικών
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0">
                        <button type="button"
                                class="btn btn-outline-secondary btn-sm app-btn-sm theme-toggle-btn"
                                id="themeToggleBtn"
                                title="Αλλαγή θέματος">
                            <i class="bi bi-moon-stars" id="themeToggleIcon"></i>
                        </button>
                        @if (isLoggedIn)
                        {
                            <div class="text-end me-2">
                                <div class="small fw-semibold text-dark">
                                    @(!string.IsNullOrWhiteSpace(fullName) ? fullName : username)
                                </div>
                                <div class="small text-muted">
                                    @roleName
                                </div>
                            </div>

                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm app-btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>Αποσύνδεση
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm app-btn-sm">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Σύνδεση
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show auto-dismiss-alert" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle me-2"></i>
                        <div>@TempData["SuccessMessage"]</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Κλείσιμο"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show auto-dismiss-alert" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <div>@TempData["ErrorMessage"]</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Κλείσιμο"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-white app-footer py-3 mt-4">
        <div class="container d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3">
            <div class="app-footer-left small text-muted">
                © 2026 <span class="fw-semibold text-dark">Panel App</span>
            </div>

            <div class="app-footer-center small text-center text-muted">
                @if (Env.IsDevelopment())
                {
                    <span class="badge bg-warning text-dark me-2">DEV</span>
                    <span>Έκδοση δοκιμών · v1.0 Pilot</span>
                }
                else if (Env.IsProduction())
                {
                    <span class="badge bg-success me-2">PROD</span>
                    <span>Έκδοση παραγωγής · v1.0</span>
                }
                else
                {
                    <span>v1.0</span>
                }

                <div class="small mt-1">
                    <a asp-controller="Home"
                           asp-action="Privacy"
                           class="text-decoration-none text-muted">
                        Privacy
                    </a>
                </div>
            </div>

            <div class="app-footer-right d-flex align-items-center gap-2">
                <img src="~/images/output-onlinepngtools.png" alt="Company Logo" class="app-footer-logo" />
                <div class="small text-muted text-center text-lg-start">
                    <div class="fw-semibold text-dark">Company Name</div>
                    <div>@DateTime.Now.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
