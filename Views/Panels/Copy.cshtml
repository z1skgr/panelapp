@model panelapp.ViewModels.CopyPanelViewModel
@using panelapp.Constants
@{
    ViewData["Title"] = "Αντιγραφή Πίνακα";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Αντιγραφή Πίνακα</h1>
        <p class="text-muted mb-0">Δημιουργία νέου πίνακα από υπάρχον</p>
    </div>

    <div>
        <a asp-action="Details" asp-route-id="@Model.SourcePanelID" class="btn btn-outline-secondary app-btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Επιστροφή
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">Πηγή Αντιγραφής</h2>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted small">Αρχικός Πίνακας</div>
                <div class="fw-semibold">@Model.SourcePanelCode</div>
            </div>

            <div class="col-md-4">
                <div class="text-muted small">Αρχικός Πελάτης</div>
                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.SourceCustomerName) ? "-" : Model.SourceCustomerName)</div>
            </div>

            <div class="col-md-4">
                <div class="text-muted small">Νέος Κωδικός</div>
                <div class="fw-bold text-primary">@Model.SuggestedPanelCode</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Copy" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="SourcePanelID" />
            <input type="hidden" asp-for="SourcePanelCode" />
            <input type="hidden" asp-for="SourceCustomerName" />
            <input type="hidden" asp-for="SuggestedPanelCode" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
            }

            <div class="alert alert-info mb-4">
                Η αντιγραφή επιτρέπεται και από ολοκληρωμένους πίνακες.
                Ο νέος πίνακας θα δημιουργηθεί αυτόματα με τον επόμενο διαθέσιμο κωδικό
                και με κατάσταση <strong>"@PanelStatuses.ToDisplayLabel(PanelStatuses.UnderConstruction)"</strong>.
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CustomerID" class="form-label"></label>
                    <select asp-for="CustomerID" asp-items="Model.Customers" class="form-select">
                        <option value="">-- Επιλογή Πελάτη --</option>
                    </select>
                    <span asp-validation-for="CustomerID" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />

            <h2 class="h5 mb-3">Επιλογές Αντιγραφής</h2>

            <div class="row g-3">
                
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" checked disabled />
                    <input type="hidden" asp-for="CopyMaterials" value="true" />
                    <label asp-for="CopyMaterials" class="form-check-label"></label>
                </div>

                <div class="col-md-4">
                    <div class="form-check mb-2">
                        <input asp-for="CopyDiscounts" class="form-check-input" />
                        <label asp-for="CopyDiscounts" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-check mb-3">
                        <input asp-for="CopyManualPrices" class="form-check-input" />
                        <label asp-for="CopyManualPrices" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                <button type="submit" class="btn btn-primary app-btn">
                    <i class="bi bi-files me-1"></i>Δημιουργία Αντιγράφου
                </button>

                <a asp-action="Details" asp-route-id="@Model.SourcePanelID" class="btn btn-outline-secondary app-btn">
                    Ακύρωση
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}