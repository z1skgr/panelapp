@model panelapp.ViewModels.AddMaterialToPanelViewModel

@{
    ViewData["Title"] = "Add Material";
}

<h2>Add Material to Panel</h2>

<p><strong>Panel:</strong> @Model.PanelCode</p>

<form asp-action="AddMaterial" method="post">
    <input type="hidden" asp-for="PanelID" />
    <input type="hidden" asp-for="PanelCode" />

    <div class="mb-3">
        <label asp-for="MaterialID" class="form-label">Material</label>
        <select asp-for="MaterialID" asp-items="Model.Materials" class="form-control">
            <option value="">-- Select Material --</option>
        </select>
        <span asp-validation-for="MaterialID" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantity" class="form-label">Quantity</label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DiscountPercent" class="form-label">Discount %</label>
        <input asp-for="DiscountPercent" class="form-control" />
        <span asp-validation-for="DiscountPercent" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary app-btn">
        <i class="bi bi-check-circle-me-1"></i> Αποθήκευση
    </button>
    <a asp-action="Details" asp-route-id="@Model.PanelID" class="btn btn-outline-secondary app-btn">Πίσω</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}