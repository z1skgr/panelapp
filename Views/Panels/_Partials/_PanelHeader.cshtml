@model panelapp.ViewModels.PanelDetailsViewModel

<div class="app-page-header mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-lightning-charge me-1"></i>
            Στοιχεία Πίνακα
        </h1>
        <p class="text-muted mb-0">Προβολή στοιχείων, υλικών και κοστολόγησης</p>
    </div>

    <div class="d-flex gap-2 dashboard-hero-actions">
        <a asp-action="Edit"
           asp-route-id="@Model.Panel.PanelID"
           class="btn btn-outline-primary hero-action-btn">
            <i class="bi bi-pencil-square me-1"></i>
            <span>Επεξεργασία</span>
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary hero-action-btn">
            <i class="bi bi-arrow-left"></i>
            <span>Επιστροφή</span>
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4 app-info-card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">Κωδικός</div>
                <div class="fw-bold text-primary">@Model.Panel.PanelCode</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Πελάτης</div>
                <div class="fw-semibold">
                    @(Model.Panel.Customer?.CustomerName ?? Model.Panel.CustomerName ?? "-")
                </div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Κατάσταση</div>
                <partial name="_PanelStatusBadge" model="Model.Panel.Status" />
            </div>

            <div class="col-12">
                <div class="text-muted small">Περιγραφή</div>
                <div class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(Model.Panel.Description) ? "-" : Model.Panel.Description)
                </div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Ημερομηνία δημιουργίας</div>
                <div class="fw-semibold">@Model.Panel.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Ημερομηνία Ενημέρωσης</div>
                <div class="fw-semibold">@Model.Panel.LastModifiedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>
    </div>
</div>