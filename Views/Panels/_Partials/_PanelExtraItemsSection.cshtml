@model panelapp.ViewModels.PanelDetailsViewModel
@using Microsoft.AspNetCore.Http
@using panelapp.Constants

@{
    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var isCompleted = string.Equals(
        PanelStatuses.Normalize(Model.Panel.Status),
        PanelStatuses.Completed,
        StringComparison.OrdinalIgnoreCase);

    var panelLocked = isCompleted && !isAdmin;
}



<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3 mt-4">
    <div>
        <h2 class="h5 mb-1">Λοιπά Υλικά Πίνακα</h2>
        <p class="text-muted mb-0">Χειροκίνητες γραμμές κόστους που κρατούνται ως snapshot</p>
    </div>
</div>
@if (!Model.ExtraItems.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-4 text-center">
            <i class="bi bi-plus-square fs-1 text-muted"></i>
            <h3 class="h5 mt-3">Δεν έχουν προστεθεί ακόμα λοιπά υλικά</h3>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Κωδικός</th>
                            <th>Περιγραφή</th>
                            <th>Μονάδα</th>
                            <th class="text-end text-nowrap">Ποσότητα</th>
                            <th class="text-end text-nowrap">Τιμή</th>
                            <th class="text-end text-nowrap">Έκπτωση</th>
                            <th class="text-end text-nowrap">Σύνολο</th>
                            <th class="text-end text-nowrap">Ενέργειες</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.ExtraItems)
                        {
                            <tr>
                                <td>@item.ItemCode</td>
                                <td>@item.Description</td>
                                <td>@item.Unit</td>
                                <td class="text-end text-nowrap">@item.Quantity.ToString("N2")</td>
                                <td class="text-end text-nowrap">@item.UnitPrice.ToString("N2") €</td>
                                <td class="text-end text-nowrap">@item.DiscountPercent.ToString("N2") %</td>
                                <td class="text-end text-nowrap">
                                    <strong>@item.TotalPrice.ToString("N2") €</strong>
                                </td>

                                <td class="text-end text-nowrap">
                                    @if (!panelLocked || isAdmin)
                                    {
                                        <div class="d-inline-flex gap-1">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editExtraItemModal_@item.PanelExtraItemID">
                                                <i class="bi bi-pencil"></i>
                                            </button>

                                            <form asp-controller="Panels"
                                                  asp-action="DeleteExtraItem"
                                                  asp-route-id="@item.PanelExtraItemID"
                                                  method="post"
                                                  class="d-inline js-confirm-form"
                                                  data-confirm-title="Διαγραφή ερμάριο υλικό"
                                                  data-confirm-message="Να αφαιρεθεί το λοιπό υλικό @item.PanelExtraItemID από τον πίνακα"
                                                  data-confirm-button="Διαγραφή">
                                                

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger icon-btn"
                                                        title="Διαγραφή"
                                                        data-bs-toggle="tooltip">
                                                    <i class="bi bi-trash"></i>
                                                </button>

                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>

                                            
                        }
                    </tbody>

                    <tfoot class="border-top">
                        <tr class="bg-body-tertiary">
                            <td colspan="6" class="text-end fw-bold">
                                Σύνολο Λοιπών Υλικών
                            </td>
                            <td class="text-end text-nowrap fw-bold">
                                @Model.ExtraItemsGrandTotal.ToString("N2") €
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>

                            
            </div>
            
        </div>
    </div>
}

@foreach (var item in Model.ExtraItems)
{
    <div class="modal fade"
         id="editExtraItemModal_@item.PanelExtraItemID"
         tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content bg-body text-body">
                <form asp-controller="Panels" asp-action="UpdateExtraItem" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="PanelExtraItemID" value="@item.PanelExtraItemID" />
                    <input type="hidden" name="PanelID" value="@Model.Panel.PanelID" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />

                    <div class="modal-header">
                        <h5 class="modal-title">Επεξεργασία Λοιπού Υλικού</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Κωδικός</label>
                                <input name="ItemCode"
                                       value="@item.ItemCode"
                                       class="form-control" />
                            </div>

                            <div class="col-md-8">
                                <label class="form-label">Περιγραφή</label>
                                <input name="Description"
                                       value="@item.Description"
                                       class="form-control"
                                       required />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Μονάδα</label>
                                <select name="Unit" class="form-select">
                                    <option value="pcs" selected="@(item.Unit == "pcs")">pcs</option>
                                    <option value="meters" selected="@(item.Unit == "meters")">meters</option>
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Ποσότητα</label>
                                <input name="Quantity"
                                       value="@item.Quantity.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0.01" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Τιμή</label>
                                <input name="UnitPrice"
                                       value="@item.UnitPrice.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Έκπτωση %</label>
                                <input name="DiscountPercent"
                                       value="@item.DiscountPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       max="100" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Ακύρωση
                        </button>

                        <button type="submit" class="btn btn-primary app-btn has-loading-state d-inline-flex align-items-center justify-content-center">
                            <span class="btn-text">
                                Αποθήκευση
                            </span>

                            <span class="btn-spinner">
                                <span class="spinner-border spinner-border-sm"></span>
                                Αποθήκευση...
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}