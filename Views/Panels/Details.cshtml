@model panelapp.ViewModels.PanelDetailsViewModel
@using Microsoft.AspNetCore.Http
@using panelapp.Constants

@{
    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var isCompleted = string.Equals(
        PanelStatuses.Normalize(Model.Panel.Status),
        PanelStatuses.Completed,
        StringComparison.OrdinalIgnoreCase);
    var panelLocked = isCompleted && !isAdmin;

    
    ViewData["Title"] = "Στοιχεία Πίνακα";
}




<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Στοιχεία Πίνακα</h1>
        <p class="text-muted mb-0">Προβολή στοιχείων, υλικών και κοστολόγησης</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary app-btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Επιστροφή
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">Κωδικός</div>
                <div class="fw-bold text-primary">@Model.Panel.PanelCode</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Πελάτης</div>
                <div class="fw-semibold">@(Model.Panel.Customer?.CustomerName ?? Model.Panel.CustomerName ?? "-")</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Κατάσταση</div>
                <partial name="_PanelStatusBadge" model="Model.Panel.Status" />
            </div>
            <div class="col-12">
                <div class="text-muted small">Περιγραφή</div>
                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Panel.Description) ? "-" : Model.Panel.Description)</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">Ημερομηνία δημιουργίας</div>
                <div class="fw-semibold">@Model.Panel.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Ημερομηνία Ενημέρωσης</div>
                <div class="fw-semibold">@Model.Panel.LastModifiedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            
        </div>
    </div>
</div>

@if (!panelLocked)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Προσθήκη Υλικού</h2>

            <form asp-action="AddMaterialInline" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="PanelID" value="@Model.Panel.PanelID" />

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Προμηθευτής</label>
                        <select id="supplierSelect" name="SupplierID" class="form-select">
                            <option value="">-- Όλοι οι προμηθευτές --</option>

                            @foreach (var supplier in Model.AddMaterialForm.Suppliers)
                            {
                                if (Model.AddMaterialForm.SupplierID == int.Parse(supplier.Value))
                                {
                                    <option value="@supplier.Value" selected>@supplier.Text</option>
                                }
                                else
                                {
                                    <option value="@supplier.Value">@supplier.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-5 mb-3">
                        <label class="form-label">Αναζήτηση Υλικού</label>
                        <input id="materialSearch"
                               name="MaterialSearch"
                               value="@Model.AddMaterialForm.MaterialSearch"
                               class="form-control"
                               placeholder="Κωδικός ή περιγραφή..." />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Υλικό</label>
                        <select id="materialSelect" name="MaterialID" class="form-select">
                            <option value="">-- Επιλογή Υλικού --</option>
                        </select>
                        <div id="materialMessage" class="text-muted mt-1 small"></div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Ποσότητα</label>
                        <input name="Quantity" value="1" class="form-control" type="number" min="1" step="1" />
                    </div>

                    <div class="col-md-2 mb-3">
                        <label class="form-label">Έκπτωση %</label>
                        <input name="DiscountPercent" value="0" class="form-control" type="number" min="0" max="100" step="0.01" />
                    </div>

                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary app-btn">
                            <i class="bi bi-plus-circle me-1"></i>Προσθήκη Υλικού
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-secondary mb-4">
        Δεν επιτρέπεται προσθήκη ή αλλαγή υλικών σε ολοκληρωμένο πίνακα από απλό χρήστη.
    </div>
}



<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
    <div>
        <h2 class="h5 mb-1">Υλικά Πίνακα</h2>
        <p class="text-muted mb-0">Λίστα υλικών και υπολογισμός κόστους</p>
    </div>

    @if (Model.Materials.Any())
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
    <div class="dropdown">
        <button class="btn btn-outline-success dropdown-toggle px-4"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
            <i class="bi bi-download"></i> Export
        </button>

        <ul class="dropdown-menu shadow-sm">
            <li>
                <a class="dropdown-item"
                   asp-action="ExportCSV"
                   asp-route-id="@Model.Panel.PanelID">
                    CSV
                </a>
            </li>
            <li>
                <a class="dropdown-item"
                   asp-action="ExportExcel"
                   asp-route-id="@Model.Panel.PanelID">
                    Excel
                </a>
            </li>
        </ul>
    </div>

    <a asp-action="Copy"
       asp-route-id="@Model.Panel.PanelID"
       class="btn btn-outline-primary px-4">
        <i class="bi bi-files"></i> Αντιγραφή
    </a>
</div>
    }
</div>

@if (!Model.Materials.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body py-5 text-center">
            <i class="bi bi-box-seam fs-1 text-muted"></i>
            <h3 class="h5 mt-3">Δεν έχουν προστεθεί ακόμα υλικά</h3>
            <p class="text-muted mb-0">Μπορείς να προσθέσεις υλικά από την παραπάνω φόρμα.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Κωδικός</th>
                            <th>Περιγραφή</th>
                            <th>Προμηθευτής</th>
                            <th>Ποσότητα</th>
                            <th class="text-end text-nowrap">Τιμή Μονάδας €</th>
                            <th class="text-end text-nowrap">Τιμή KAT €</th>
                            <th class="text-end text-nowrap">Έκπτωση %</th>
                            <th class="text-end text-nowrap">Τιμή NET €</th>
                            <th>Χειρ. τιμή</th>
                            <th class="text-end">Ενέργειες</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Materials)
                        {
                            <tr>
                                <td class="fw-semibold">@item.MaterialCode</td>
                                <td>@item.MaterialDescription</td>
                                <td>@item.SupplierName</td>
                                <td>@item.Quantity</td>
                                <td class="text-end text-nowrap">@item.UnitPrice.ToString("0.00€")</td>
                                <td class="text-end text-nowrap">@item.OriginalTotalPrice.ToString("0.00€")</td>
                                <td class="text-end text-nowrap">@item.DiscountPercent.ToString("0.##")</td>
                                <td class="fw-semibold">@item.NetValue.ToString("0.00€")</td>
                                <td>
                                    @if (item.IsManualPrice)
                                    {
                                        <span class="badge bg-warning text-dark">Ναι</span>

                                        @if (!string.IsNullOrWhiteSpace(item.ManualPriceReason))
                                        {
                                            <div class="small text-muted mt-1">@item.ManualPriceReason</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">Όχι</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-1">
                                        @if (isAdmin)
                                        {
                                            <a asp-action="EditMaterialAdmin"
                                               asp-route-id="@item.PanelMaterialID"
                                               class="btn btn-sm btn-outline-warning"
                                               title="Επεξεργασία από Admin">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <form asp-action="RemoveMaterial" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="panelMaterialId" value="@item.PanelMaterialID" />
                                                <input type="hidden" name="panelId" value="@Model.Panel.PanelID" />
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm app-btn-sm"
                                                        title="Αφαίρεση"
                                                        onclick="return confirm('Θέλεις σίγουρα να αφαιρέσεις αυτό το υλικό από τον πίνακα;');">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                        else if (!panelLocked)
                                        {
                                            <a asp-action="EditMaterial"
                                               asp-route-id="@item.PanelMaterialID"
                                               class="btn btn-outline-secondary btn-sm app-btn-sm"
                                               title="Επεξεργασία">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <form asp-action="RemoveMaterial" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="panelMaterialId" value="@item.PanelMaterialID" />
                                                <input type="hidden" name="panelId" value="@Model.Panel.PanelID" />
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm app-btn-sm"
                                                        title="Αφαίρεση"
                                                        onclick="return confirm('Θέλεις σίγουρα να αφαιρέσεις αυτό το υλικό από τον πίνακα;');">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">Σύνολο χωρίς έκπτωση</div>
                    <div class="h5 mb-0">@Model.TotalWithoutDiscount.ToString("0.00") €</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Τελικό σύνολο</div>
                    <div class="h4 mb-0 fw-bold text-success">@Model.GrandTotal.ToString("0.00") €</div>
                </div>
            </div>
        </div>
    </div>
}
@section Scripts {
    <script>
        const supplierSelect = document.getElementById('supplierSelect');
        const materialSearch = document.getElementById('materialSearch');
        const materialSelect = document.getElementById('materialSelect');
        const materialMessage = document.getElementById('materialMessage');

        if (!supplierSelect || !materialSearch || !materialSelect || !materialMessage) {
            console.warn("Material filter elements not found.");
        } else {
            let debounceTimer;

            function resetMaterialDropdown(message) {
                materialSelect.innerHTML = '<option value="">-- Επιλογή Υλικού --</option>';
                materialSelect.value = "";
                materialSelect.disabled = true;
                materialMessage.innerText = message || "";
            }

            async function loadMaterials() {
                const supplierId = supplierSelect.value;
                const term = materialSearch.value.trim();

                materialSelect.innerHTML = '<option value="">-- Επιλογή Υλικού --</option>';
                materialSelect.value = "";

                if (!supplierId) {
                    resetMaterialDropdown("Επίλεξε προμηθευτή για να δεις υλικά.");
                    return;
                }

                materialSelect.disabled = true;
                materialMessage.innerText = "Φόρτωση...";

                const url = `/Panels/SearchMaterials?supplierId=${encodeURIComponent(supplierId)}&term=${encodeURIComponent(term)}`;

                try {
                    const response = await fetch(url);
                    const data = await response.json();

                    materialSelect.innerHTML = '<option value="">-- Επιλογή Υλικού --</option>';

                    const items = Array.isArray(data.items) ? data.items : [];

                    if (data.needsSearch) {
                        materialSelect.disabled = true;
                        materialMessage.innerText = data.message || "Μεγάλος αριθμός υλικών. Κάνε αναζήτηση.";
                        return;
                    }

                    if (items.length === 0) {
                        materialSelect.disabled = false;
                        materialMessage.innerText = data.message || "Δεν βρέθηκαν υλικά.";
                        return;
                    }

                    for (const item of items) {
                        const option = document.createElement('option');
                        option.value = item.value;
                        option.text = item.text;
                        materialSelect.appendChild(option);
                    }

                    materialSelect.disabled = false;

                    if (data.message) {
                        materialMessage.innerText = data.message;
                    } else {
                        materialMessage.innerText = term
                            ? `Βρέθηκαν ${items.length} υλικά με βάση το φίλτρο.`
                            : `Βρέθηκαν ${items.length} υλικά.`;
                    }
                } catch (error) {
                    console.error('Error loading materials:', error);
                    resetMaterialDropdown("Σφάλμα φόρτωσης υλικών.");
                }
            }

            supplierSelect.addEventListener('change', function () {
                materialSearch.value = "";
                resetMaterialDropdown("Φόρτωση υλικών...");
                loadMaterials();
            });

            materialSearch.addEventListener('input', function () {
                clearTimeout(debounceTimer);

                if (!supplierSelect.value) {
                    resetMaterialDropdown("Επίλεξε προμηθευτή για να δεις υλικά.");
                    return;
                }

                debounceTimer = setTimeout(loadMaterials, 250);
            });

            document.addEventListener('DOMContentLoaded', function () {
                if (supplierSelect.value) {
                    loadMaterials();
                } else {
                    resetMaterialDropdown("Επίλεξε προμηθευτή για να δεις υλικά.");
                }
            });
        }
    </script>
}