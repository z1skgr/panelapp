@model panelapp.ViewModels.PanelDetailsViewModel
@using Microsoft.AspNetCore.Http
@using panelapp.Constants

@{
    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var isCompleted = string.Equals(
        PanelStatuses.Normalize(Model.Panel.Status),
        PanelStatuses.Completed,
        StringComparison.OrdinalIgnoreCase);
    var panelLocked = isCompleted && !isAdmin;

    
    ViewData["Title"] = "Στοιχεία Πίνακα";
}

<div class="panel-details-page">

    <partial name="_Partials/_PanelHeader" model="Model" />

    <div class="row g-4">
        <div class="col-lg-8">

            <partial name="_Partials/_PanelAddMaterialForm" model="Model" />
            <partial name="_Partials/_PanelMaterialsSection" model="Model" />

            <partial name="_Partials/_PanelAddCabinetForm" model="Model" />
            <partial name="_Partials/_PanelCabinetsSection" model="Model" />

            <partial name="_Partials/_PanelAddExtraItemForm" model="Model" />
            <partial name="_Partials/_PanelExtraItemsSection" model="Model" />

        </div>

        <div class="col-lg-4">
            <partial name="_Partials/_PanelPricingSummarySection" model="Model" />

        </div>
    </div>


</div>
<partial name="_SupplierDiscountsModal"
         model="Model.SupplierDiscountsModal" />
 

@section Scripts {
    <script src="~/js/panel-details-materials.js" asp-append-version="true"></script>
    <script src="~/js/panel-details-cabinets.js" asp-append-version="true"></script>
}