@model panelapp.ViewModels.CustomerIndexViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Πελάτες";

    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var customers = Model.Customers;
    var currentSearch = Model.SearchTerm ?? string.Empty;
    var hasFilters = !string.IsNullOrWhiteSpace(currentSearch);

}

<div class="accordion" id="customersAccordion">
    @for (int i = 0; i < customers.Count; i++)
    {
        var customer = customers[i];
        var collapseId = $"customer-collapse-{customer.CustomerID}";
        var headingId = $"customer-heading-{customer.CustomerID}";
        var panelPageKey = $"panelPage_{customer.CustomerID}";
        var isExpanded = Model.ExpandedCustomerId == customer.CustomerID;

        var currentPanelPage = 1;
        if (Context.Request.Query.ContainsKey(panelPageKey) &&
            int.TryParse(Context.Request.Query[panelPageKey], out var parsedPanelPage) &&
            parsedPanelPage > 0)
        {
            currentPanelPage = parsedPanelPage;
        }

        var totalPanels = customer.Panels.Count;
        var panelTotalPages = (int)Math.Ceiling(totalPanels / (double)Model.PanelsPerCustomer);

        if (panelTotalPages == 0)
        {
            panelTotalPages = 1;
        }

        if (currentPanelPage > panelTotalPages)
        {
            currentPanelPage = panelTotalPages;
        }

        var panels = customer.Panels
            .OrderByDescending(p => p.CreatedDate)
            .Skip((currentPanelPage - 1) * Model.PanelsPerCustomer)
            .Take(Model.PanelsPerCustomer)
            .ToList();

        <div class="accordion-item border-0 shadow-sm mb-3 rounded-3 overflow-hidden" id="customer-@customer.CustomerID">
            <h2 class="accordion-header" id="@headingId">
                <button class="accordion-button @(isExpanded ? "" : "collapsed") fw-semibold"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#@collapseId"
                        aria-expanded="@(isExpanded ? "true" : "false")"
                        aria-controls="@collapseId">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center w-100 me-3 gap-2">
                        <span>
                            <i class="bi bi-person-badge me-2 text-muted"></i>@customer.CustomerName
                        </span>

                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            @if (!string.IsNullOrWhiteSpace(customer.VatNumber))
                            {
                                <span class="badge rounded-pill bg-light text-dark border">
                                    ΑΦΜ: @customer.VatNumber
                                </span>
                            }

                            <span class="badge rounded-pill bg-light text-dark border">
                                Σύνολο Πινάκων: @totalPanels
                            </span>

                            @if (customer.Active)
                            {
                                <span class="badge rounded-pill bg-success">Ενεργός</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary">Ανενεργός</span>
                            }
                        </div>
                    </div>
                </button>
            </h2>

            <div id="@collapseId"
                 class="accordion-collapse collapse @(isExpanded ? "show" : "")"
                 aria-labelledby="@headingId"
                 data-bs-parent="#customersAccordion">
                <div class="accordion-body p-0">
                    @if (totalPanels == 0)
                    {
                        <div class="p-4 text-muted">
                            Δεν υπάρχουν πίνακες για αυτόν τον πελάτη.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Κωδικός Πίνακα</th>
                                        <th>Περιγραφή</th>
                                        <th>Κατάσταση</th>
                                        <th>Ημ/νία</th>
                                        <th class="text-end">Ενέργειες</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var panel in panels)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@panel.PanelCode</td>
                                            <td>@(string.IsNullOrWhiteSpace(panel.Description) ? "-" : panel.Description)</td>
                                            <td><partial name="_PanelStatusBadge" model="panel.Status" /></td>
                                            <td>@panel.CreatedDate.ToString("dd/MM/yyyy")</td>
                                            <td class="text-end">
                                                <a asp-controller="Panels"
                                                   asp-action="Details"
                                                   asp-route-id="@panel.PanelID"
                                                   class="btn btn-outline-secondary btn-sm app-btn-sm">
                                                    <i class="bi bi-eye me-1"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (panelTotalPages > 1)
                        {
                            <div id="panel-pagination-@customer.CustomerID" class="p-3 border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span class="text-muted small">
                                    Σελίδα @currentPanelPage από @panelTotalPages
                                </span>

                                <div class="d-flex gap-2">
                                    @{
                                        var prevPanelRoutes = new Dictionary<string, string?>
                                        {
                                            ["searchTerm"] = Model.SearchTerm,
                                            ["page"] = Model.CurrentPage.ToString(),
                                            ["customerPageSize"] = Model.CustomerPageSize.ToString(),
                                            ["panelsPerCustomer"] = Model.PanelsPerCustomer.ToString(),
                                            [$"panelPage_{customer.CustomerID}"] = (currentPanelPage - 1).ToString(),
                                            ["expandedCustomerId"] = customer.CustomerID.ToString(),
                                            ["scrollTo"] = $"panel-pagination-{customer.CustomerID}"
                                        };

                                        var nextPanelRoutes = new Dictionary<string, string?>
                                        {
                                            ["searchTerm"] = Model.SearchTerm,
                                            ["page"] = Model.CurrentPage.ToString(),
                                            ["customerPageSize"] = Model.CustomerPageSize.ToString(),
                                            ["panelsPerCustomer"] = Model.PanelsPerCustomer.ToString(),
                                            [$"panelPage_{customer.CustomerID}"] = (currentPanelPage + 1).ToString(),
                                            ["expandedCustomerId"] = customer.CustomerID.ToString(),
                                            ["scrollTo"] = $"panel-pagination-{customer.CustomerID}"
                                        };
                                    }

                                    <a class="btn btn-sm btn-outline-secondary @(currentPanelPage == 1 ? "disabled" : "")"
                                       asp-action="Index"
                                       asp-all-route-data="prevPanelRoutes">
                                        Προηγούμενοι Πίνακες
                                    </a>

                                    <a class="btn btn-sm btn-outline-secondary @(currentPanelPage == panelTotalPages ? "disabled" : "")"
                                       asp-action="Index"
                                       asp-all-route-data="nextPanelRoutes">
                                        Επόμενοι Πίνακες
                                    </a>
                                </div>
                            </div>
                        }
                    }

                    @if (isAdmin)
                    {
                        <div class="p-3 border-top bg-light-subtle d-flex justify-content-end">
                            <a asp-action="Edit"
                               asp-route-id="@customer.CustomerID"
                               class="btn btn-outline-primary btn-sm app-btn-sm" title="Επεξεργασία Πελάτη">
                                <i class="bi bi-pencil me-1"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>