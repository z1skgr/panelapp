@model panelapp.ViewModels.CustomerIndexViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Πελάτες";

    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var customers = Model.Customers;
    var currentSearch = Model.SearchTerm ?? string.Empty;
    var hasFilters = !string.IsNullOrWhiteSpace(currentSearch);

}


    <div class="page-header">
        <div class="page-header-content">
                <h1 class="page-title">
                    <i class="bi bi-people me-1"></i>
                    Πελάτες
                </h1>
                <p class="page-subtitle mb-0">Προβολή πελατών και των πινάκων τους</p>

        </div>

        <div class="page-header-actions">
        <a asp-action="Create" class="btn btn-primary app-btn" title="Νέος Πελάτης">
                <i class="bi bi-plus-circle me-1"></i>
                <span>Νέος Πελάτης</span>
            </a>
            <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-secondary app-btn"
                   title="Επιστροφή">
                <i class="bi bi-arrow-left"></i>
                <span>Επιστροφή</span>
            </a>
        </div>
    </div>



<partial name="_Partials/_CustomersSearchBar" model="Model" />

@if (hasFilters)
{
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <span class="badge bg-info text-dark">
            Αποτελέσματα: @Model.TotalCount
        </span>

        <span class="badge bg-light text-dark border">
            Αναζήτηση: @currentSearch
        </span>
    </div>
}

@if (customers == null || customers.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-people fs-1 text-muted"></i>
            <h2 class="h5 mt-3">Δεν βρέθηκαν πελάτες</h2>
            <p class="text-muted mb-4">Δεν υπάρχουν πελάτες με τα επιλεγμένα κριτήρια.</p>
        </div>
    </div>
}
else
{
    <partial name="_Partials/_CustomersAccordion" model="Model" />
    
    <partial name="_Partials/_CustomersPagination" model="Model" />

    
}

@section Scripts {
    <script src="~/js/customers-index.js" asp-append-version="true"></script>
    <script src="~/js/page-scroll.js" asp-append-version="true"></script>
}