@model panelapp.Models.Customer

@{
    ViewData["Title"] = "Επεξεργασία Πελάτη";
    var hasPanels = ViewBag.HasPanels != null && (bool)ViewBag.HasPanels;
}
<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-title">
            <i class="bi bi-person-gear"></i>
            Επεξεργασία Πελάτη
        </h1>

        <p class="page-subtitle">
            Ενημέρωση στοιχείων πελάτη και επικοινωνίας
        </p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index"
           class="btn btn-outline-secondary app-btn">
            <i class="bi bi-arrow-left"></i>
            <span>Επιστροφή</span>
        </a>
    </div>
</div>
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                @if (hasPanels)
                {
                    <div class="alert alert-warning">
                        Δεν επιτρέπεται αλλαγή στο <strong>Όνομα Πελάτη</strong> και στο <strong>ΑΦΜ</strong>,
                        επειδή υπάρχουν ήδη συνδεδεμένοι πίνακες.
                    </div>
                }

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CustomerID" />
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CustomerName" class="form-label">Όνομα Πελάτη</label>
                            @if (hasPanels)
                            {
                                <input asp-for="CustomerName" class="form-control" readonly />
                            }
                            else
                            {
                                <input asp-for="CustomerName" class="form-control" />
                            }
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="VatNumber" class="form-label">ΑΦΜ</label>
                            @if (hasPanels)
                            {
                                <input asp-for="VatNumber" class="form-control" readonly />
                            }
                            else
                            {
                                <input asp-for="VatNumber"
                                       class="form-control"
                                       maxlength="9"
                                       inputmode="numeric"
                                       pattern="[0-9]{9}"
                                       placeholder="9 ψηφία"
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 9);" />
                            }
                            <span asp-validation-for="VatNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Τηλέφωνο</label>
                            <input asp-for="Phone"
                                   class="form-control"
                                   maxlength="10"
                                   inputmode="numeric"
                                   pattern="[0-9]{0,10}"
                                   autocomplete="tel"
                                   placeholder="μέχρι 10 ψηφία"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email"
                                   type="email"
                                   class="form-control"
                                   autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ContactPerson" class="form-label">Υπεύθυνος Επικοινωνίας</label>
                            <input asp-for="ContactPerson" class="form-control" />
                            <span asp-validation-for="ContactPerson" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label">Διεύθυνση</label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Σχόλια</label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Προαιρετικές σημειώσεις για τον πελάτη"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Active" class="form-check-input" />
                                <label asp-for="Active" class="form-check-label">Ενεργός</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary app-btn">
                            <i class="bi bi-arrow-left me-1"></i>Επιστροφή
                        </a>

                        <button type="submit" class="btn btn-primary app-btn has-loading-state d-inline-flex align-items-center justify-content-center">
                            <span class="btn-text">
                                <i class="bi bi-save me-1"></i>
                                Αποθήκευση
                            </span>

                            <span class="btn-spinner">
                                <span class="spinner-border spinner-border-sm"></span>
                                Αποθήκευση...
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}