@model panelapp.ViewModels.MaterialIndexViewModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Κατάλογος Υλικών";

    var roleName = Context.Session.GetString("RoleName");
    var isAdmin = string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase);

    var currentSearch = Model.SearchTerm ?? string.Empty;
    var currentSupplierId = Model.SupplierFilterId;
    
    var supplierFilter = Model.SupplierFilter ?? "all";
    var hasFilters = !string.IsNullOrWhiteSpace(currentSearch)
                     || currentSupplierId.HasValue
                     || supplierFilter != "all";
}


    
<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-title">
            <i class="bi bi-box-seam me-1"></i>
            Κατάλογος Υλικών
        </h1>
        <p class="page-subtitle">Προβολή υλικών απο προμηθευτές</p>
    </div>

    @if (isAdmin)
    {
        <div class="page-header-actions">
            <div class="dropdown">
                <button class="btn btn-primary app-btn"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="true"
                        >
                    <i class="bi bi-plus-circle me-1"></i>
                    <span>Νέο Υλικό</span>
                </button>

                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li>
                        <a asp-action="Create" class="dropdown-item">
                            <i class="bi bi-lightning-charge me-2"></i>
                            Νέο Διακοπτικό Υλικό
                        </a>
                    </li>

                    <li>
                        <a asp-action="CreateCabinet" class="dropdown-item">
                            <i class="bi bi-box-seam me-2"></i>
                            Νέο Ερμάριο
                        </a>
                    </li>


                    <li><hr class="dropdown-divider" /></li>

                    <li>
                        <a asp-action="Import" class="dropdown-item">
                            <i class="bi bi-file-earmark-excel me-2"></i>
                            Εισαγωγή Υλικών από Excel
                        </a>
                    </li>
                </ul>
            </div>
            <a asp-controller="Home"
                   asp-action="Index"
               class="btn btn-outline-secondary app-btn"
                   title="Επιστροφή">
                <i class="bi bi-arrow-left"></i>
                <span>Επιστροφή</span>
            </a>
            
            
        </div>
    }
    else
    {
        <div class="d-flex flex-wrap gap-2 dashboard-hero-actions">
        <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-outline-secondary hero-action-btn">
            <i class="bi bi-arrow-left me-1"></i>
            Επιστροφή
        </a>
        </div>
    }
</div>

<partial name="_Partials/_MaterialsSearchBar" model="Model" />

@if (hasFilters)
{
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <span class="badge bg-info text-dark">
            Προμηθευτές: @Model.TotalSupplierCount
        </span>

        @if (supplierFilter == "active")
        {
            <span class="badge bg-success">
                Ενεργοί προμηθευτές
            </span>
        }
        else
        {
            <span class="badge bg-secondary">
                Όλοι οι προμηθευτές
            </span>
        }

        @if (!string.IsNullOrWhiteSpace(currentSearch))
        {
            <span class="badge bg-light text-dark border">
                Αναζήτηση: @currentSearch
            </span>
        }
    </div>
}

@if (Model.Groups == null || Model.Groups.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-search fs-1 text-muted"></i>
            <h2 class="h5 mt-3">Δεν βρέθηκαν υλικά</h2>
            <p class="text-muted mb-4">Δεν βρέθηκαν υλικά με τα επιλεγμένα κριτήρια αναζήτησης.</p>
        </div>
    </div>
}
else
{
    <partial name="_Partials/_MaterialsAccordion" model="Model" />
    <partial name="_Partials/_MaterialsPagination" model="Model" />
    
}

@section Scripts {
    <script src="~/js/materials-index.js" asp-append-version="true"></script>
    <script src="~/js/page-scroll.js" asp-append-version="true"></script>
}