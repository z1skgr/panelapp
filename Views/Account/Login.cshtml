@model panelapp.ViewModels.LoginViewModel

@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Σύνδεση";
}

<div class="auth-shell">
    <div class="auth-card card border-0">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <div class="auth-logo mb-3">
                    <img src="~/images/output-onlinepngtools.png"
                         alt="PanelApp Logo"
                         class="auth-logo-img" />
                </div>

                <div class="auth-kicker mb-3">PanelApp</div>

                <h1 class="auth-app-title mb-1">Panel App</h1>

                <p class="auth-subtitle mb-0">
                    Σύστημα διαχείρισης ηλεκτρολογικών πινάκων και υλικών
                </p>
            </div>

            <div class="auth-section-title mb-4 text-center">
                <h2 class="h4 mb-1">Σύνδεση χρήστη</h2>
                <p class="text-muted small mb-0">
                    Εισάγετε τα στοιχεία πρόσβασής σας για να συνεχίσετε.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
            {
                <div class="alert alert-danger auth-alert" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    @Model.ErrorMessage
                </div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger auth-alert"></div>
            }

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Όνομα χρήστη</label>
                    <input asp-for="Username"
                           class="form-control form-control-lg auth-input"
                           placeholder="Εισάγετε το όνομα χρήστη"
                           autocomplete="username"
                           autofocus />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Κωδικός</label>

                    <div class="input-group auth-password-group">
                        <input asp-for="Password"
                               asp-format=""
                               type="password"
                               class="form-control form-control-lg auth-input"
                               placeholder="Εισάγετε τον κωδικό"
                               autocomplete="current-password"
                               id="passwordInput" />

                        <button class="btn auth-password-toggle"
                                type="button"
                                id="togglePasswordButton"
                                aria-label="Εμφάνιση ή απόκρυψη κωδικού">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>

                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success btn-lg auth-submit-btn">
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Σύνδεση
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const passwordInput = document.getElementById("passwordInput");
            const togglePasswordButton = document.getElementById("togglePasswordButton");

            if (!passwordInput || !togglePasswordButton) return;

            togglePasswordButton.addEventListener("click", function () {
                const isPassword = passwordInput.type === "password";

                passwordInput.type = isPassword ? "text" : "password";
                togglePasswordButton.innerHTML = isPassword
                    ? '<i class="bi bi-eye-slash"></i>'
                    : '<i class="bi bi-eye"></i>';
            });
        });
    </script>

}