@model panelapp.ViewModels.OfferDetailsViewModel
@using System.Globalization


@{
    ViewData["Title"] = "Προσφορά";
    ViewData["FullWidth"] = true;
    var offer = Model.Offer;
}

<div class="card offer-card border-0 mb-4">
    <div class="card-header border-0">
        <h5 class="mb-0"><i class="bi bi-box text-orange me-2"></i>Ερμάρια Προσφοράς</h5>
    </div>

    <div class="card-body p-0">
        @if (!offer.OfferCabinets.Any())
        {
            <div class="p-4 text-muted">Δεν υπάρχουν ερμάρια στην προσφορά.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Κωδικός</th>
                            <th>Περιγραφή</th>
                            <th>Προμηθευτής</th>
                            <th class="text-end text-nowrap">Ποσότητα</th>
                            <th class="text-end text-nowrap">Τιμή</th>
                            <th class="text-end text-nowrap">Έκπτωση</th>
                            <th class="text-end text-nowrap">Σύνολο</th>
                            <th class="text-end text-nowrap">Ενέργειες</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in offer.OfferCabinets)
                        {
                            <tr>
                                <td>@item.Cabinet?.CabinetCode</td>
                                <td>@item.Cabinet?.Description</td>
                                <td>@item.Supplier?.SupplierName</td>
                                <td class="text-end text-nowrap">@item.Quantity.ToString("N2")</td>
                                <td class="text-end text-nowrap">@item.UnitPrice.ToString("N2") €</td>
                                <td class="text-end text-nowrap">@item.DiscountPercent.ToString("N2") %</td>
                                <td class="text-end text-nowrap"><strong>@item.LineNetTotal.ToString("N2") €</strong></td>
                                <td class="text-end text-nowrap">
                                    <div class="d-flex justify-content-end gap-1">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary icon-btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editCabinetModal_@item.OfferCabinetID"
                                                title="Επεξεργασία">
                                            <i class="bi bi-pencil"></i>
                                        </button>

                                        <form asp-controller="Offers"
                                              asp-action="DeleteCabinet"
                                              asp-route-id="@item.OfferCabinetID"
                                              method="post"
                                              class="d-inline js-confirm-form"
                                              data-confirm-title="Διαγραφή ερμάριο υλικό"
                                              data-confirm-message="Να αφαιρεθεί το υλικό @item.OfferCabinetID από την προσφορά @offer.OfferCode;"
                                              data-confirm-button="Διαγραφή">
                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger icon-btn"
                                                    title="Διαγραφή"
                                                    data-bs-toggle="tooltip">
                                            </button>
                                        </form>
                                    </div>

                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot class="border-top">
                        <tr class="bg-body-tertiary">
                            <td colspan="6" class="text-end"><strong>Σύνολο Ερμαρίων</strong></td>
                            <td class="text-end text-nowrap"><strong>@Model.CabinetsNetTotal.ToString("N2") €</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

        }
    </div>
</div>


@foreach (var item in offer.OfferCabinets)
{
    <div class="modal fade"
         id="editCabinetModal_@item.OfferCabinetID"
         tabindex="-1">

        <div class="modal-dialog modal-lg">
            <div class="modal-content bg-body text-body">

                <form asp-controller="Offers"
                      asp-action="UpdateCabinet"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden" name="OfferCabinetID" value="@item.OfferCabinetID" />
                    <input type="hidden" name="OfferID" value="@offer.OfferID" />
                    <input type="hidden"
                           name="RowVersion"
                           value="@Convert.ToBase64String(item.RowVersion)" />

                    <div class="modal-header">
                        <h5 class="modal-title">Επεξεργασία Ερμαρίου</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal">
                        </button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <strong>@item.Cabinet?.CabinetCode</strong>
                            <div class="text-body-secondary">
                                @item.Cabinet?.Description
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Ποσότητα</label>
                                <input name="Quantity"
                                       value="@item.Quantity.ToString("0.##", CultureInfo.InvariantCulture)"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0.01" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Τιμή Μονάδας</label>
                                <input name="UnitPrice"
                                       value="@item.UnitPrice.ToString("0.##", CultureInfo.InvariantCulture)"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Έκπτωση %</label>
                                <input name="DiscountPercent"
                                       value="@item.DiscountPercent.ToString("0.##", CultureInfo.InvariantCulture)"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       max="100" />
                            </div>

                            <div class="col-md-12">
                                <div class="form-check">
                                    <input type="hidden" name="IsManualPrice" value="false" />

                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="IsManualPrice"
                                           value="true"
                                    @(item.IsManualPrice ? "checked" : "") />

                                    <label class="form-check-label">
                                        Χειροκίνητη τιμή
                                    </label>
                                </div>

                                <div class="form-text">
                                    Αν δεν είναι ενεργό, η τιμή θα ενημερωθεί από τον τρέχοντα κατάλογο ερμαρίων.
                                </div>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Αιτιολογία χειροκίνητης τιμής</label>
                                <textarea name="ManualPriceReason"
                                          class="form-control"
                                          rows="3">@item.ManualPriceReason</textarea>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Ακύρωση
                        </button>

                        <button type="submit" class="btn btn-primary app-btn has-loading-state d-inline-flex align-items-center justify-content-center">
                            <span class="btn-text">
                                <i class="bi bi-save me-1"></i>
                                Αποθήκευση
                            </span>

                            <span class="btn-spinner">
                                <span class="spinner-border spinner-border-sm"></span>
                                Αποθήκευση...
                            </span>
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
}