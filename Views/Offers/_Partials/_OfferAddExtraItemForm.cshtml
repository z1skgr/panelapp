@model panelapp.ViewModels.OfferDetailsViewModel


@{
    ViewData["Title"] = "Προσφορά";
    ViewData["FullWidth"] = true;
    var offer = Model.Offer;
}

<div class="card offer-card border-0 mb-4">
    <div class="card-header border-0">
        <h5 class="mb-0">
            <i class="bi bi-plus-square"></i>
            Προσθήκη Λοιπού Υλικού
        </h5>
    </div>

    <div class="card-body">
        <form asp-controller="Offers" asp-action="AddExtraItem" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="OfferID" value="@offer.OfferID" />

            <div class="row g-3 align-items-end">
                <div class="col-xl-2 col-md-3">
                    <label class="form-label">Κωδικός</label>
                    <input name="ItemCode" class="form-control" placeholder="Προαιρετικό" />
                </div>

                <div class="col-xl-3 col-md-9">
                    <label class="form-label">Περιγραφή</label>
                    <input name="Description" class="form-control" required />
                </div>

                <div class="col-xl-1 col-md-3">
                    <label class="form-label">Μονάδα</label>
                    <select name="Unit" class="form-select">
                        <option value="pcs">pcs</option>
                        <option value="meters">meters</option>
                    </select>
                </div>

                <div class="col-xl-1 col-md-3">
                    <label class="form-label">Ποσότητα</label>
                    <input name="Quantity" value="1" class="form-control" type="number" step="0.01" min="0.01" />
                </div>

                <div class="col-xl-1 col-md-3">
                    <label class="form-label">Τιμή</label>
                    <input name="UnitPrice" value="0" class="form-control" type="number" step="0.01" min="0" />
                </div>

                <div class="col-xl-2 col-md-3">
                    <label class="form-label">Έκπτωση %</label>
                    <input name="DiscountPercent" value="0" class="form-control" type="number" step="0.01" min="0" max="100" />
                </div>

                <div class="col-xl-2 col-md-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i>
                        Προσθήκη Λοιπού Υλικού
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>