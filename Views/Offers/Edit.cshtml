@model panelapp.ViewModels.OfferEditViewModel

@{
    ViewData["Title"] = "Επεξεργασία Προσφοράς";
}

<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-title">
            <i class="bi bi-pencil-square"></i>
            Επεξεργασία Προσφοράς
        </h1>

        <p class="page-subtitle">
            @Model.OfferCode
        </p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Details"
           asp-route-id="@Model.OfferID"
           class="btn btn-outline-secondary app-btn">
            <i class="bi bi-arrow-left me-1"></i>
            Επιστροφή
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="OfferID" />
            <input type="hidden" asp-for="OfferCode" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CustomerID" class="form-label">Πελάτης</label>
                    <select asp-for="CustomerID"
                            asp-items="Model.Customers"
                            class="form-select">
                        <option value="">-- Επιλογή Πελάτη --</option>
                    </select>
                    <span asp-validation-for="CustomerID" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Κωδικός Προσφοράς</label>
                    <input value="@Model.OfferCode"
                           class="form-control"
                           readonly />
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label">Περιγραφή</label>
                    <textarea asp-for="Description"
                              class="form-control"
                              rows="3"
                              placeholder="Περιγραφή προσφοράς"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Notes" class="form-label">Σημειώσεις</label>
                    <textarea asp-for="Notes"
                              class="form-control"
                              rows="4"
                              placeholder="Εσωτερικές σημειώσεις"></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                <button type="submit" class="btn btn-primary app-btn has-loading-state d-inline-flex align-items-center justify-content-center">
                    <span class="btn-text">
                        <i class="bi bi-save me-1"></i>
                        Αποθήκευση
                    </span>

                    <span class="btn-spinner">
                        <span class="spinner-border spinner-border-sm"></span>
                        Αποθήκευση...
                    </span>
                </button>

                <a asp-action="Details"
                   asp-route-id="@Model.OfferID"
                   class="btn btn-outline-secondary app-btn">
                    Ακύρωση
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}