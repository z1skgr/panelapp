@model IEnumerable<panelapp.Models.Offer>
@using panelapp.Helpers

@{
    ViewData["Title"] = "Προσφορές";

    var search = ViewBag.Search as string ?? string.Empty;
    var selectedStatus = ViewBag.Status as string ?? string.Empty;
    var hasFilters = !string.IsNullOrWhiteSpace(search) || !string.IsNullOrWhiteSpace(selectedStatus);
}

<div class="offers-index-page">

    <div class="page-header">
        <div class="page-header-content">
            <h2 class="page-title">
                <i class="bi bi-file-earmark-text me-1"></i>
                Προσφορές
            </h2>
            <p class="page-subtitle">Διαχείριση προσφορών και κοστολόγησης έργων</p>
        </div>

        <div class="page-header-actions">
            <a asp-action="Create" class="btn btn-primary app-btn" title="Νέα Προσφορά">
                <i class="bi bi-plus-circle me-1"></i>
                <span>Νέα Προσφορά</span>
            </a>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary app-btn" title="Επιστροφή">
                <i class="bi bi-arrow-left"></i>
                <span>Επιστροφή</span>
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4 offers-filter-card">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">

                <div class="col-md-7">
                    <label for="offersSearchInput" class="form-label">Αναζήτηση</label>
                    <div class="position-relative">
                        <input type="text"
                               id="offersSearchInput"
                               name="search"
                               value="@search"
                               class="form-control"
                               placeholder="Κωδικός, πελάτης ή περιγραφή..." />

                        <span class="position-absolute top-50 end-0 translate-middle-y pe-3 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                    </div>
                </div>

                <div class="col-md-3">
                    <label for="offersStatusSelect" class="form-label">Κατάσταση</label>
                    <select name="status" id="offersStatusSelect" class="form-select">
                        <option value="">Όλες</option>

                        @foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status" selected="@(selectedStatus == status)">
                                @OfferStatusBadgeHelper.GetGreekLabel(status)
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label d-block">&nbsp;</label>
                    <a asp-action="Index" class="btn btn-outline-secondary app-btn w-100">
                        <i class="bi bi-x-circle me-1"></i>
                        Καθαρισμός
                    </a>
                </div>

            </form>
        </div>
    </div>

    @if (hasFilters)
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <span class="badge bg-info text-dark">Φίλτρα ενεργά</span>

            @if (!string.IsNullOrWhiteSpace(search))
            {
                <span class="badge bg-light text-dark border">Αναζήτηση: @search</span>
            }

            @if (!string.IsNullOrWhiteSpace(selectedStatus))
            {
                <span class="badge bg-light text-dark border">Κατάσταση: @OfferStatusBadgeHelper.GetGreekLabel(selectedStatus)</span>
            }
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body py-5 text-center">
                <i class="bi bi-file-earmark-text fs-1 text-muted"></i>
                <h3 class="h5 mt-3">Δεν βρέθηκαν προσφορές</h3>
                <p class="text-muted mb-3">Δεν υπάρχουν προσφορές με τα επιλεγμένα κριτήρια.</p>

                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a asp-action="Index" class="btn btn-outline-secondary app-btn">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        Καθαρισμός
                    </a>

                    <a asp-action="Create" class="btn btn-primary app-btn">
                        <i class="bi bi-plus-circle me-1"></i>
                        Νέα Προσφορά
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm offers-table-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Πίνακας</th>
                                <th>Κωδικός Προσφοράς</th>
                                <th>Πελάτης</th>
                                <th>Κατάσταση</th>
                                <th>Είδη</th>
                                <th>Σύνολο</th>
                                <th>Ενημερώθηκαν</th>
                                <th class="text-end">Ενέργειες</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var offer in Model)
                            {
                                <tr>
                                    <td>
                                        @if (offer.PanelID.HasValue && offer.Panel != null)
                                        {
                                            <a asp-controller="Panels" asp-action="Details" asp-route-id="@offer.PanelID">
                                                @offer.Panel.PanelCode
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td class="fw-semibold">@offer.OfferCode</td>
                                    <td>@offer.CustomerName</td>

                                    <td>
                                        <span class="badge @OfferStatusBadgeHelper.GetBadgeClass(offer.Status)">
                                            @OfferStatusBadgeHelper.GetGreekLabel(offer.Status)
                                        </span>
                                    </td>

                                    <td>@(offer.OfferMaterials.Count + offer.OfferCabinets.Count + offer.OfferExtraItems.Count)</td>
                                    <td class="fw-semibold text-nowrap">@offer.FinalOfferTotal.ToString("N2") €</td>
                                    <td class="text-nowrap">@offer.LastModifiedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>

                                    <td class="text-end">
                                        <div class="table-actions justify-content-end" role="group">
                                            <a asp-action="Details"
                                               asp-route-id="@offer.OfferID"
                                               class="btn btn-sm btn-outline-primary icon-btn"
                                               title="Προβολή"
                                               data-bs-toggle="tooltip">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <a asp-controller="Offers"
                                               asp-action="Edit"
                                               asp-route-id="@offer.OfferID"
                                               class="btn btn-outline-primary icon-btn"
                                               title="Επεξεργασία">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>


                                            <form asp-action="Delete"
                                                  asp-route-id="@offer.OfferID"
                                                  method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Να διαγραφεί η προσφορά;');">

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger icon-btn"
                                                        title="Διαγραφή"
                                                        data-bs-toggle="tooltip">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center mb-0">

                    <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@ViewBag.Search"
                           asp-route-status="@ViewBag.Status"
                           asp-route-page="@(ViewBag.Page - 1)">
                            Προηγούμενη
                        </a>
                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.Page == i ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-search="@ViewBag.Search"
                               asp-route-status="@ViewBag.Status"
                               asp-route-page="@i">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@ViewBag.Search"
                           asp-route-status="@ViewBag.Status"
                           asp-route-page="@(ViewBag.Page + 1)">
                            Επόμενη
                        </a>
                    </li>

                </ul>
            </nav>
        }
    }

</div>

@section Scripts {
    <script src="~/js/offer-search.js" asp-append-version="true"></script>
}
