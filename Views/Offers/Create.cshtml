@model panelapp.Models.Offer

@{
    ViewData["Title"] = "Νέα Προσφορά";
}

<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-title">
            <i class="bi bi-file-earmark-plus"></i>
            Νέα Προσφορά
        </h1>

        <p class="page-subtitle">
            Δημιουργία νέας προσφοράς για πελάτη
        </p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline-secondary app-btn">
            <i class="bi bi-arrow-left me-1"></i>
            Επιστροφή
        </a>
    </div>
</div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="row g-3">

                    <div class="col-md-4">
                        <label asp-for="OfferCode" class="form-label">
                            Κωδικός Προσφοράς
                        </label>

                        <input asp-for="OfferCode"
                               class="form-control"
                               readonly />

                        <span asp-validation-for="OfferCode"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="CustomerID" class="form-label">
                            Πελάτης
                        </label>

                        <select asp-for="CustomerID"
                                class="form-select"
                                id="customerSelect">

                            <option value="">
                                -- Επιλογή Πελάτη --
                            </option>

                            @foreach (var customer in ViewBag.Customers)
                            {
                                <option value="@customer.CustomerID"
                                        data-name="@customer.CustomerName">
                                    @customer.CustomerName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="CustomerName" class="form-label">
                            Επωνυμία Πελάτη
                        </label>

                        <input asp-for="CustomerName"
                               class="form-control"
                               id="customerNameInput"
                               placeholder="Συμπληρώνεται αυτόματα από τον πελάτη ή γράφεται χειροκίνητα" />

                        <span asp-validation-for="CustomerName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label">
                            Περιγραφή
                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Περιγραφή προσφοράς / πίνακα"></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Notes" class="form-label">
                            Σημειώσεις
                        </label>

                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Εσωτερικές ή εμπορικές σημειώσεις"></textarea>

                        <span asp-validation-for="Notes"
                              class="text-danger">
                        </span>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index"
                           class="btn btn-outline-secondary">
                        Ακύρωση
                    </a>

                    <button type="submit"
                            class="btn btn-primary">
                        <i class="bi bi-save"></i>
                        Δημιουργία Προσφοράς
                    </button>

                </div>

            </form>

        </div>
    </div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const customerSelect = document.getElementById("customerSelect");
        const customerNameInput = document.getElementById("customerNameInput");

        customerSelect.addEventListener("change", function () {
            const selectedOption = this.options[this.selectedIndex];
            const customerName = selectedOption.getAttribute("data-name");

            if (customerName) {
                customerNameInput.value = customerName;
            }
        });
    </script>
}